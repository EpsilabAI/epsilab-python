# Required — your Epsilab API key (get one at https://www.epsilab.com/settings)
EPSILAB_API_KEY=sk-your-api-key

# Optional — override the API base URL (defaults to production)
# EPSILAB_API_BASE=https://api.epsilab.com

# Optional — HTTP request timeout in seconds (default: 120)
# EPSILAB_HTTP_TIMEOUT=120
